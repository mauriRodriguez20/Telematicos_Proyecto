# Puerto publico en el host
PUBLIC_PORT=8080

# Conexion MySQL para Docker Compose
DB_HOST=mysql
DB_USER=root
DB_PASSWORD=
DB_NAME=inventario_productos
DB_PORT=3306
MYSQL_PUBLIC_PORT=3307
MYSQL_ROOT_PASSWORD=

# Puerto interno de cada backend
PORT=3000

# Politica de balanceo activa (documentada en nginx.conf)
# Opciones: round_robin | least_conn | ip_hash
BALANCING_POLICY=round_robin
